(rules
 (processor
  (post
   (upgrade (lambda (x) x) :<=)))
 (mapping
  (zero 0)
  (ra   1)
  (sp   2)
  (gp   3)
  (tp   4)
  (t0   5)
  (t1   6)
  (t2   7)
  (s0   8)
  (s1   9)
  (a0  10)
  (a1  11)
  (a2  12)
  (a3  13)
  (a4  14)
  (a5  15)
  (a6  16)
  (a7  17)
  (s2  18)
  (s3  19)
  (s4  20)
  (s5  21)
  (s6  22)
  (s7  23)
  (s8  24)
  (s9  25)
  (s10 26)
  (s11 27)
  (t3  28)
  (t4  29)
  (t5  30)
  (t6  31))
 (function
  (set-global        (x) x)
  (set-label2        (x) x)
  (get-label2        (x) x)
  (get-offest        (x) (* (string->number (second (string-split (symbol->string x) ":"))) 4))
  (offset            (x) (immcode32 x))
  (add      (rd rs1 rs2) (write-bits-32 "0000000"                      (reg rs2 5) (reg rs1 5) "000"              (reg rd 5) "0110011"))
  (sub      (rd rs1 rs2) (write-bits-32 "0100000"                      (reg rs2 5) (reg rs1 5) "000"              (reg rd 5) "0110011"))
  (rem      (rd rs1 rs2) (write-bits-32 "0000001"                      (reg rs2 5) (reg rs1 5) "110"              (reg rd 5) "0110011"))
  (div      (rd rs1 rs2) (write-bits-32 "0000001"                      (reg rs2 5) (reg rs1 5) "100"              (reg rd 5) "0110011"))
  (subi     (rd rs1 imm) (write-bits-32 (mcode (immcode32 (- 0 imm)) "11:0" )      (reg rs1 5) "000"              (reg rd 5) "0010011"))
  (auipc        (rd imm) (write-bits-32 (mcode (immcode32 imm) "31:12")                                           (reg rd 5) "0010111"))
  (addi     (rd rs1 imm) (write-bits-32 (mcode (immcode32 imm) "11:0" )            (reg rs1 5) "000"              (reg rd 5) "0010011"))
  (addiw    (rd rs1 imm) (write-bits-32 (mcode (immcode32 imm) "11:0" )            (reg rs1 5) "000"              (reg rd 5) "0011011"))
  (lui          (rd imm) (write-bits-32 (mcode (immcode32 imm) "31:12")                                           (reg rd 5) "0110111"))
  (lbu     (rd  rs1 imm) (write-bits-32 (mcode (immcode32 imm) "11:0")             (reg rs1 5) "100"              (reg rd 5) "0000011"))
  (sw      (rs2 rs1 imm) (write-bits-32 (mcode (immcode32 imm) "11:5") (reg rs2 5) (reg rs1 5) "010"  (mcode (immcode32 imm) "4:0") "0100011"))
  (lw      (rd  rs1 imm) (write-bits-32 (mcode (immcode32 imm) "11:0")             (reg rs1 5) "010"              (reg rd 5) "0000011"))
  (sb      (rs2 rs1 imm) (write-bits-32 (mcode (immcode32 imm) "11:5") (reg rs2 5) (reg rs1 5) "000"  (mcode (immcode32 imm) "4:0") "0100011"))
  (j               (off) (write-bits-32 (mcode (immcode32 off) "20|10:1|11|19:12")                                 (reg 0 5) "1101111"))
  (jal          (rd off) (write-bits-32 (mcode (immcode32 off) "20|10:1|11|19:12")                                (reg rd 5) "1101111"))
  (jalr    (rd  rs1 off) (write-bits-32 (mcode (immcode32 off) "11:0")             (reg rs1 5) "000"              (reg rd 5) "1100111"))
  (ecall              () (write-bits-32 "000000000000"                                 "00000" "000"                 "00000" "1110011"))
  (bgt     (rs1 rs2 off) (write-bits-32 (mcode (immcode32 off) "12|10:5") (reg rs1 5) (reg rs2 5) "100" (mcode off "4:1|11") "1100011"))
  (bge     (rs1 rs2 off) (write-bits-32 (mcode (immcode32 off) "12|10:5") (reg rs1 5) (reg rs2 5) "101" (mcode off "4:1|11") "1100011")))
 (macro
  (*** lui sp, 0x80010   slli sp, sp, 32    srli sp, sp, 32  ***)
  (*** "10000000000000010000000100110111" "00000001000000001000100010010011" "00000001000000001010100010010011" ***)
  (global      (x)           (lui sp "10000000000000010000000000000000"))
  (label       (x)           ())
  (-=          (x imm)       (subi x x (car imm)))
  (+=          (x imm)       (addi x x (car imm)))
  (/=          (x y)         (div  x x (car y)))
  (=+          (x y imm)     (add  x y (car imm)))
  (=-          (x y z)       (sub  x y (car z)))
  (=%          (x y z)       (rem  x y (car z)))
  (++          (x)           (addi (car x) (car x) 1))
  (--          (x)           (addi (car x) (car x) -1))
  (store-word  (x y imm)     (sw x y (car imm)))
  (load-word   (x y imm)     (lw x y (car imm)))
  (store-byte  (x y imm)     (sb x y (car imm)))
  (load-byte   (x y imm)     (lbu x y (car imm)))
  (<-          (x y)         (addi x (car y) 0))
  (->          (x y)         (addi (car y) x 0))
  (*** call        (label)       (insts (auipc ra (offsetHi label)) (jalr ra ra (offsetLo label))) ***)
  (call        (label)       (jal ra (get-offest (car label))))
  (syscall     ()            (ecall))
  (*** branch=     (x y label)   (beq x y "00110011001100110011001100110011") ***)
  (branch>     (x y label)   (bgt x y (offset (get-offest (car label)))))
  (branch>=    (x y label)   (bge x y (offset (get-offest (car label)))))
  (jump        (label)       (j (offset (get-offest (car label)))))
  (ret         ()            (jalr zero ra 0))))

